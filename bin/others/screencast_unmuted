#!/bin/bash
# Запись экрана с системным звуком + микрофон (опционально)
# Зависимости: wf-recorder, slurp, pactl

OUTPUT="$HOME/Videos/screencast-$(date +%Y%m%d-%H%M%S).mp4"

notify() {
  local title="$1" msg="$2" urgency="${3:-normal}"
  echo "[$(date '+%H:%M:%S')] $title: $msg"
  command -v notify-send &>/dev/null &&
    notify-send -u "$urgency" "$title" "$msg"
}

# ── Зависимости ───────────────────────────────────────────────────────────────
for cmd in pactl; do
  command -v "$cmd" &>/dev/null || {
    notify "Ошибка" "Установите $cmd" "critical"
    exit 1
  }
done

# ── Источники звука ───────────────────────────────────────────────────────────
# Монитор дефолтного синка = системный звук (всё что играет)
SYSTEM_AUDIO="$(pactl get-default-sink).monitor"

# Дефолтный микрофон
MIC_SOURCE="$(pactl get-default-source)"

# Если дефолтный source уже является монитором — mic недоступен
if [[ "$MIC_SOURCE" == *.monitor ]]; then
  MIC_SOURCE=""
fi

# ── Виртуальный микс: система + микрофон через PipeWire ───────────────────────
# Временный null-sink который объединяет оба источника
setup_combined_audio() {
  # Временный виртуальный синк для микса
  COMBINED_SINK=$(pactl load-module module-null-sink \
    sink_name=screencast_mix \
    sink_properties=device.description=ScreencastMix 2>/dev/null)

  if [ -z "$COMBINED_SINK" ]; then
    # Не удалось — использовать истемный звук
    echo "$SYSTEM_AUDIO"
    return
  fi

  # Перенаправить системный монитор в микс
  pactl load-module module-loopback \
    source="$SYSTEM_AUDIO" \
    sink=screencast_mix \
    latency_msec=50 &>/dev/null

  # Перенаправить микрофон в микс (если есть)
  if [ -n "$MIC_SOURCE" ]; then
    pactl load-module module-loopback \
      source="$MIC_SOURCE" \
      sink=screencast_mix \
      latency_msec=50 &>/dev/null
  fi

  echo "screencast_mix.monitor"
}

cleanup_combined_audio() {
  pactl unload-module module-loopback 2>/dev/null || true
  [ -n "$COMBINED_SINK" ] &&
    pactl unload-module "$COMBINED_SINK" 2>/dev/null || true
}

# ── Зависимости по сессии проверяются позже

# ── Определение сессии ───────────────────────────────────────────────────────
IS_WAYLAND=false
IS_X11=false
[ "$XDG_SESSION_TYPE" = "wayland" ] || [ -n "$WAYLAND_DISPLAY" ] && IS_WAYLAND=true
[ "$XDG_SESSION_TYPE" = "x11" ] || [ -n "$DISPLAY" ] && IS_X11=true

if ! $IS_WAYLAND && ! $IS_X11; then
  notify "Ошибка" "Не удалось определить тип сессии" "critical"
  exit 1
fi

# Проверка зависимостей по сессии
if $IS_WAYLAND; then
  for cmd in wf-recorder slurp; do
    command -v "$cmd" &>/dev/null || {
      notify "Ошибка" "Установите $cmd: sudo pacman -S $cmd" "critical"
      exit 1
    }
  done
else
  for cmd in ffmpeg xrandr; do
    command -v "$cmd" &>/dev/null || {
      notify "Ошибка" "Установите $cmd" "critical"
      exit 1
    }
  done
fi

# ── Выбор области (только Wayland) ───────────────────────────────────────────
AREA=""
if $IS_WAYLAND; then
  notify "Выбор области" "Выберите область для записи"
  AREA=$(slurp 2>/dev/null)
  [ -z "$AREA" ] && {
    notify "Отменено" "Область не выбрана" "critical"
    exit 1
  }
fi

# ── Настройка аудио ───────────────────────────────────────────────────────────
if [ -n "$MIC_SOURCE" ]; then
  notify "Аудио" "Система + микрофон → виртуальный микс"
  AUDIO_SOURCE=$(setup_combined_audio)
  trap cleanup_combined_audio EXIT
else
  notify "Аудио" "Только системный звук: $SYSTEM_AUDIO"
  AUDIO_SOURCE="$SYSTEM_AUDIO"
fi

# ── Запись ────────────────────────────────────────────────────────────────────
notify "Запись" "Начало записи. Ctrl+C для остановки."

cleanup_recording() {
  [ -n "$WF_PID" ] && kill -SIGINT "$WF_PID" 2>/dev/null
  wait "$WF_PID" 2>/dev/null
  notify "Остановка" "Запись остановлена"
  rm -f /tmp/screencast.pid
}
trap cleanup_recording INT TERM

if $IS_WAYLAND; then
  # Wayland — wf-recorder
  wf-recorder \
    -g "$AREA" \
    -f "$OUTPUT" \
    --codec libx264 \
    --audio="$AUDIO_SOURCE" \
    --no-dmabuf &
  WF_PID=$!
  echo "$WF_PID" >/tmp/screencast.pid

elif $IS_X11; then
  # X11 — ffmpeg x11grab
  RES=$(xrandr 2>/dev/null | grep "\*" | head -1 | awk "{print \$1}")
  [ -z "$RES" ] && RES="1366x768"
  notify "Запись" "X11: $RES | Аудио: $AUDIO_SOURCE"

  ffmpeg -hide_banner \
    -f pulse -i "$AUDIO_SOURCE" \
    -f x11grab \
    -video_size "$RES" \
    -framerate 30 \
    -i ":0.0" \
    -c:v libx264 -crf 23 -preset fast \
    -pix_fmt yuv420p \
    -c:a aac -b:a 128k \
    -y "$OUTPUT" &
  WF_PID=$!
  echo "$WF_PID" >/tmp/screencast.pid
fi

wait $WF_PID
EXIT_CODE=$?

# Сброс trap
trap - INT TERM EXIT
cleanup_combined_audio 2>/dev/null

# ── Результат ─────────────────────────────────────────────────────────────────
# EXIT_CODE 130/255 = завершение сигналом (Ctrl+C) = OK
if [ -f "$OUTPUT" ] && [ -s "$OUTPUT" ]; then
  SIZE=$(du -h "$OUTPUT" 2>/dev/null | cut -f1)
  notify "Готово" "$OUTPUT ($SIZE)"
else
  notify "Ошибка" "Файл не создан" "critical"
  exit 1
fi
