#!/usr/bin/env bash
# Audio control for Hyprland / Waybar

STEP=5
COMBINE_MODULE_FILE="/tmp/audio_combine_module"

sinks() { pactl list short sinks | awk '!/ScreencastMix|combined/ {print $2}'; }
default() { pactl get-default-sink; }

case "$1" in
up) swayosd-client --output-volume raise ;;
down) swayosd-client --output-volume lower ;;
mute) swayosd-client --output-volume mute-toggle ;;

next-sink)
  mapfile -t s < <(sinks)
  cur=$(default)
  for ((i = 0; i < ${#s[@]}; i++)); do
    if [[ "${s[$i]}" == "$cur" ]]; then
      next="${s[$(((i + 1) % ${#s[@]}))]}"
      pactl set-default-sink "$next"
      notify-send "Audio" "$next"
      break
    fi
  done
  ;;

sink)
  [[ -z "$2" ]] && echo "Usage: $(basename "$0") sink <index|name>" && exit 1
  if [[ "$2" =~ ^[0-9]+$ ]]; then
    name=$(pactl list short sinks | awk "NR==$(($2 + 1)) {print \$2}")
  else
    name="$2"
  fi
  [[ -z "$name" ]] && echo "Sink not found: $2" && exit 1
  pactl set-default-sink "$name"
  notify-send "Audio" "$name"
  ;;

sink-all)
  while read -r sink; do
    case "$2" in
    up) pactl set-sink-volume "$sink" +${STEP}% ;;
    down) pactl set-sink-volume "$sink" -${STEP}% ;;
    mute) pactl set-sink-mute "$sink" toggle ;;
    esac
  done < <(sinks)
  ;;

combine)
  if [[ -z "$2" ]]; then
    echo "Available sinks:"
    pactl list short sinks | awk '!/ScreencastMix|combined/ {printf "  [%d] %s\n", NR-1, $2}'
    echo ""
    echo "Usage: $(basename "$0") combine 0 1"
    exit 0
  fi

  [[ -f "$COMBINE_MODULE_FILE" ]] && {
    echo "Already combined. Run uncombine first."
    exit 1
  }

  mapfile -t all < <(sinks)
  slaves=""
  for idx in "${@:2}"; do
    [[ -n "${all[$idx]}" ]] && slaves+="${all[$idx]},"
  done
  slaves="${slaves%,}"

  [[ -z "$slaves" ]] && echo "No valid sinks selected" && exit 1

  mod=$(pactl load-module module-combine-sink sink_name=combined slaves="$slaves")
  echo "$mod" >"$COMBINE_MODULE_FILE"
  pactl set-default-sink combined
  notify-send "Audio" "Combined: $slaves"
  echo "Combined: $slaves"
  ;;

uncombine)
  [[ ! -f "$COMBINE_MODULE_FILE" ]] && {
    echo "No combined sink active"
    exit 1
  }
  pactl unload-module "$(cat "$COMBINE_MODULE_FILE")"
  rm -f "$COMBINE_MODULE_FILE"
  first=$(sinks | head -1)
  pactl set-default-sink "$first"
  notify-send "Audio" "Combined sink removed"
  ;;

list)
  echo "Output (Sink):"
  default_sink=$(pactl get-default-sink)
  pactl list short sinks | awk '!/ScreencastMix/ {print $2}' | while read -r name; do
    vol=$(pactl get-sink-volume "$name" | grep -oP '\d+(?=%)' | head -1)
    mute=$(pactl get-sink-mute "$name" | grep -q yes && echo " [MUTED]" || echo "")
    marker=$([[ "$name" == "$default_sink" ]] && echo "→" || echo " ")
    echo "  $marker $name ($vol%$mute)"
  done

  echo ""
  echo "Input (Source):"
  default_source=$(pactl get-default-source)
  pactl list short sources | awk '!/monitor/ {print $2}' | while read -r name; do
    vol=$(pactl get-source-volume "$name" | grep -oP '\d+(?=%)' | head -1)
    mute=$(pactl get-source-mute "$name" | grep -q yes && echo " [MUTED]" || echo "")
    marker=$([[ "$name" == "$default_source" ]] && echo "→" || echo " ")
    echo "  $marker $name ($vol%$mute)"
  done

  echo ""
  echo "Stream:"
  pactl list sink-inputs | grep -oP '(?<=Volume: front-left: )\d+ /\s*\K\d+(?=%)|(?<=application\.name = ")[^"]+|(?<=media\.name = ")[^"]+' |
    paste - - - | while IFS=$'\t' read -r vol app media; do
    echo "  $app ($vol%) — $media"
  done

  [[ -f "$COMBINE_MODULE_FILE" ]] && echo "" && echo "⚡ Combined sink active"
  ;;

*) echo "up | down | mute | next-sink | sink-all <up|down|mute> | sink <n> | combine [0 1 ..] | uncombine | list" ;;
esac
